#!/usr/bin/env python3

import boto3
import json
import os

def get_b2_client():
    config_path = os.path.join(os.path.dirname(__file__), '..', 'config', 'storage.json')
    with open(config_path, 'r') as f:
        config = json.load(f)

    session = boto3.session.Session()
    s3_client = session.client(
        service_name='s3',
        region_name='us-east-001',  # Backblaze B2 region, can be anything for S3 compatible API
        endpoint_url=config['endpoint'],
        aws_access_key_id=config['key_id'],
        aws_secret_access_key=config['application_key']
    )
    return s3_client

if __name__ == "__main__":
    try:
        client = get_b2_client()
        # Attempt to list buckets to verify credentials
        client.list_buckets()
        print("Successfully authenticated to Backblaze B2.")
    except Exception as e:
        print(f"Authentication failed: {e}")
        exit(1)
