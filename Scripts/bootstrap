#!/usr/bin/env bash

set -euo pipefail

# Configuration files
VM_CONFIG="$(dirname "$0")"/../config/vm.json
STORAGE_CONFIG="$(dirname "$0")"/../config/storage.json
CHECKPOINT_CONFIG="$(dirname "$0")"/../config/checkpoint.json

# QEMU and Backblaze scripts
QEMU_BOOT="$(dirname "$0")"/../qemu/boot
QEMU_OVERLAY="$(dirname "$0")"/../qemu/overlay
BACKBLAZE_LOGIN="$(dirname "$0")"/../backblaze/login
BACKBLAZE_DOWNLOAD="$(dirname "$0")"/../backblaze/download
BACKBLAZE_VERIFY="$(dirname "$0")"/../backblaze/verify

# VM image paths
BASE_IMAGE="$(dirname "$0")"/../vm_images/base.qcow2
OVERLAY_IMAGE="$(dirname "$0")"/../vm_images/overlay.qcow2
COMPRESSED_OVERLAY="$(dirname "$0")"/../vm_images/overlay.qcow2.zst
OVERLAY_CHECKSUM="$(dirname "$0")"/../vm_images/overlay.sha256

# QMP socket path
QMP_SOCKET_PATH="/tmp/qmp-socket-$(uuidgen)"
QMP_SOCKET_FILE="$(dirname "$0")"/../qmp_socket.txt"

mkdir -p "$(dirname "$0")"/../vm_images

echo "1. Installing dependencies..."
sudo apt-get update
sudo apt-get install -y qemu-kvm qemu-utils zstd python3 python3-pip
sudo pip3 install boto3

echo "2. Authenticating to Backblaze B2..."
"$BACKBLAZE_LOGIN"

echo "3. Downloading base.qcow2 and latest overlay.qcow2.zst..."
"$BACKBLAZE_DOWNLOAD" base.qcow2 "$BASE_IMAGE"
"$BACKBLAZE_DOWNLOAD" overlay.qcow2.zst "$COMPRESSED_OVERLAY"
"$BACKBLAZE_DOWNLOAD" overlay.sha256 "$OVERLAY_CHECKSUM"

echo "4. Verifying SHA256 for overlay..."
"$BACKBLAZE_VERIFY" "$COMPRESSED_OVERLAY" "$OVERLAY_CHECKSUM"

echo "5. Decompressing overlay..."
"$QEMU_OVERLAY" decompress "$COMPRESSED_OVERLAY" "$OVERLAY_IMAGE"

echo "6. Creating overlay if missing (this should not happen if download and decompress were successful, but as a fallback)..."
if [ ! -f "$OVERLAY_IMAGE" ]; then
    "$QEMU_OVERLAY" create "$BASE_IMAGE" "$OVERLAY_IMAGE"
fi

echo "7. Storing QMP socket path: $QMP_SOCKET_PATH"
echo "$QMP_SOCKET_PATH" > "$QMP_SOCKET_FILE"

echo "8. Booting Windows VM..."
"$QEMU_BOOT" "$BASE_IMAGE" "$OVERLAY_IMAGE" "$QMP_SOCKET_PATH"

echo "Bootstrap complete."
