#!/usr/bin/env python3

import socket
import json
import sys
import time

def send_qmp_command(qmp_path, command):
    try:
        sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        sock.connect(qmp_path)
        
        # Read QMP capabilities
        data = sock.recv(4096).decode()
        # print(f"Received: {data}")

        # Send QMP handshake
        sock.sendall(json.dumps({"execute": "qmp_capabilities"}).encode())
        data = sock.recv(4096).decode()
        # print(f"Received: {data}")

        # Send the actual command
        sock.sendall(json.dumps(command).encode())
        data = sock.recv(4096).decode()
        # print(f"Received: {data}")
        return json.loads(data)
    except Exception as e:
        print(f"Error communicating with QMP: {e}")
        sys.exit(1)
    finally:
        sock.close()

if __name__ == "__main__":
    if len(sys.argv) != 2:
        print("Usage: ./qemu/shutdown <qmp_socket_path>")
        sys.exit(1)

    qmp_path = sys.argv[1]

    print(f"Attempting to gracefully shut down QEMU via QMP socket: {qmp_path}")
    command = {"execute": "system_powerdown"}
    response = send_qmp_command(qmp_path, command)

    if "return" in response:
        print("QEMU VM powerdown command sent successfully.")
        # Give the VM some time to shut down
        time.sleep(10)
    else:
        print(f"Failed to send powerdown command: {response}")
        sys.exit(1)
