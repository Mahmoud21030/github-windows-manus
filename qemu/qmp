#!/usr/bin/env python3

import socket
import json
import sys

def send_qmp_command(qmp_path, command):
    try:
        sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        sock.connect(qmp_path)
        
        # Read QMP capabilities
        data = sock.recv(4096).decode()
        # print(f"Received: {data}")

        # Send QMP handshake
        sock.sendall(json.dumps({"execute": "qmp_capabilities"}).encode())
        data = sock.recv(4096).decode()
        # print(f"Received: {data}")

        # Send the actual command
        sock.sendall(json.dumps(command).encode())
        data = sock.recv(4096).decode()
        # print(f"Received: {data}")
        return json.loads(data)
    except Exception as e:
        print(f"Error communicating with QMP: {e}")
        sys.exit(1)
    finally:
        sock.close()

if __name__ == "__main__":
    if len(sys.argv) < 3:
        print("Usage: ./qemu/qmp <qmp_socket_path> <qmp_command_json>")
        sys.exit(1)

    qmp_path = sys.argv[1]
    qmp_command_json = sys.argv[2]

    try:
        command = json.loads(qmp_command_json)
        response = send_qmp_command(qmp_path, command)
        print(json.dumps(response, indent=2))
    except json.JSONDecodeError:
        print(f"Error: Invalid JSON command: {qmp_command_json}")
        sys.exit(1)
    except Exception as e:
        print(f"Failed to execute QMP command: {e}")
        sys.exit(1)
